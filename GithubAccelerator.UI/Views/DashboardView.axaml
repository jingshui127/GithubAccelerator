<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GithubAccelerator.UI.ViewModels"
             xmlns:controls="using:GithubAccelerator.UI.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
             x:Class="GithubAccelerator.UI.Views.DashboardView"
             x:DataType="vm:MainWindowViewModel">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid>
        <!-- 骨架屏加载状态 -->
        <Border IsVisible="{Binding IsLoading}" Padding="24">
            <StackPanel Spacing="20">
                <!-- 核心指标骨架 -->
                <Grid ColumnDefinitions="*,*,*,*" RowDefinitions="Auto">
                    <Border Grid.Column="0" Height="100" Margin="0,0,8,8" CornerRadius="12"
                            Background="{DynamicResource ControlFillColorDefaultBrush}"/>
                    <Border Grid.Column="1" Height="100" Margin="4,0,4,8" CornerRadius="12"
                            Background="{DynamicResource ControlFillColorDefaultBrush}"/>
                    <Border Grid.Column="2" Height="100" Margin="4,0,4,8" CornerRadius="12"
                            Background="{DynamicResource ControlFillColorDefaultBrush}"/>
                    <Border Grid.Column="3" Height="100" Margin="8,0,0,8" CornerRadius="12"
                            Background="{DynamicResource ControlFillColorDefaultBrush}"/>
                </Grid>
                
                <!-- 快速操作骨架 -->
                <Border Height="50" CornerRadius="12" Background="{DynamicResource ControlFillColorDefaultBrush}"/>
                
                <!-- 推荐数据源骨架 -->
                <Border Height="100" CornerRadius="12" Background="{DynamicResource ControlFillColorDefaultBrush}"/>
                
                <!-- 数据源列表骨架 -->
                <StackPanel Spacing="8">
                    <Border Height="20" Width="150" CornerRadius="4" Background="{DynamicResource ControlFillColorDefaultBrush}"
                            HorizontalAlignment="Left"/>
                    <Border Height="70" CornerRadius="10" Background="{DynamicResource ControlFillColorDefaultBrush}"/>
                    <Border Height="70" CornerRadius="10" Background="{DynamicResource ControlFillColorDefaultBrush}"/>
                    <Border Height="70" CornerRadius="10" Background="{DynamicResource ControlFillColorDefaultBrush}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 实际内容 -->
        <ScrollViewer Padding="24" Background="{DynamicResource BackgroundColor}" HorizontalAlignment="Stretch"
                      IsVisible="{Binding !IsLoading}">
            <StackPanel Spacing="20" Margin="0,0,0,24" HorizontalAlignment="Stretch">
                
                <!-- 核心监控指标 -->
                <Grid ColumnDefinitions="*,*,*,*" RowDefinitions="Auto">
                    <!-- 健康状态 -->
                    <Border Grid.Column="0" Grid.Row="0" Padding="20" Margin="0,0,8,8" CornerRadius="12"
                            Background="{Binding IsMonitoring, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#107C10|#FF8C00'}"
                            BoxShadow="0 2 8 0 #20000000">
                        <StackPanel Spacing="8">
                            <TextBlock Text="🌐 监控状态" FontSize="12" Foreground="#AAFFFFFF"/>
                            <TextBlock Text="{Binding IsMonitoring, Converter={StaticResource BoolToStringConverter}, ConverterParameter='监控中|已停止'}"
                                       FontSize="20" FontWeight="Bold" Foreground="White"/>
                        </StackPanel>
                    </Border>

                    <!-- 最佳响应时间 -->
                    <Border Grid.Column="1" Grid.Row="0" Padding="20" Margin="4,0,4,8" CornerRadius="12"
                            Background="{DynamicResource PrimaryColor}"
                            BoxShadow="0 2 8 0 #20000000">
                        <StackPanel Spacing="8">
                            <TextBlock Text="⚡ 最佳响应" FontSize="12" Foreground="#AAFFFFFF"/>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="{Binding BestSourceResponseTime}" FontSize="24" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="ms" FontSize="14" Foreground="#AAFFFFFF" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- 综合评分 -->
                    <Border Grid.Column="2" Grid.Row="0" Padding="20" Margin="4,0,4,8" CornerRadius="12"
                            Background="{DynamicResource SuccessColor}"
                            BoxShadow="0 2 8 0 #20000000">
                        <StackPanel Spacing="8">
                            <TextBlock Text="📊 综合评分" FontSize="12" Foreground="#AAFFFFFF"/>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="{Binding BestSourceScore, StringFormat={}{0:F1}}" FontSize="24" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="/100" FontSize="14" Foreground="#AAFFFFFF" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- 数据源数量 -->
                    <Border Grid.Column="3" Grid.Row="0" Padding="20" Margin="8,0,0,8" CornerRadius="12"
                            Background="{DynamicResource WarningColor}"
                            BoxShadow="0 2 8 0 #20000000">
                        <StackPanel Spacing="8">
                            <TextBlock Text="📡 数据源" FontSize="12" Foreground="#AAFFFFFF"/>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="{Binding Sources.Count}" FontSize="24" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="个" FontSize="14" Foreground="#AAFFFFFF" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- 快速操作栏 -->
                <Border Padding="16,12" CornerRadius="12"
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                            <Button Content="{Binding IsMonitoring, Converter={StaticResource BoolToStringConverter}, ConverterParameter='⏹ 停止|▶ 开始'}"
                                    Command="{Binding ToggleMonitoringCommand}"
                                    Padding="16,8" FontSize="13"/>
                            <Button Content="🔄 刷新" Command="{Binding RefreshSourcesCommand}"
                                    Padding="16,8" FontSize="13"/>
                        </StackPanel>
                        
                        <TextBlock Grid.Column="1" Text="{Binding StatusMessage}"
                                   FontSize="12" Classes="SecondaryText" 
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                            <Button Content="✅ 应用选中源" 
                                    Command="{Binding ApplySelectedSourcesCommand}"
                                    Padding="16,8" FontSize="13"
                                    IsEnabled="{Binding HasSelectedSources}"/>
                            <Button Content="🗑️ 清除Hosts" 
                                    Command="{Binding ClearAppliedHostsCommand}"
                                    Padding="16,8" FontSize="13"
                                    IsVisible="{Binding IsHostsApplied}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 推荐数据源 -->
                <Border Padding="20" CornerRadius="12"
                        Background="{DynamicResource PrimaryColor}"
                        BoxShadow="0 4 12 0 #30000000"
                        IsVisible="{Binding BestSourceName, Converter={StaticResource StringNotEmptyConverter}}">
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                        <Border Grid.Column="0" Width="48" Height="48" CornerRadius="24"
                                Background="#20FFFFFF" Margin="0,0,16,0">
                            <TextBlock Text="⭐" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                            <TextBlock Text="推荐数据源" FontSize="11" Foreground="#AAFFFFFF"/>
                            <TextBlock Text="{Binding BestSourceName}" FontSize="18" FontWeight="Bold" Foreground="White"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="24,0" MinWidth="80">
                            <TextBlock Text="响应" FontSize="10" Foreground="#AAFFFFFF" HorizontalAlignment="Center"/>
                            <TextBlock FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center">
                                <Run Text="{Binding BestSourceResponseTime}"/>
                                <Run Text="ms" FontSize="11"/>
                            </TextBlock>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="24,0" MinWidth="60">
                            <TextBlock Text="评分" FontSize="10" Foreground="#AAFFFFFF" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding BestSourceScore, StringFormat={}{0:F1}}"
                                       FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                        </StackPanel>
                        
                        <Button Grid.Column="4" Content="应用" Command="{Binding ApplyHostsCommand}"
                                Padding="16,8" FontSize="13" 
                                Background="#20FFFFFF" 
                                Foreground="White"
                                BorderThickness="0">
                            <Button.Styles>
                                <Style Selector="Button:pointerover">
                                    <Setter Property="Background" Value="#40FFFFFF"/>
                                </Style>
                                <Style Selector="Button:pressed">
                                    <Setter Property="Background" Value="#60FFFFFF"/>
                                </Style>
                            </Button.Styles>
                        </Button>
                    </Grid>
                </Border>

                <!-- 数据源列表 -->
                <StackPanel Spacing="12">
                    <DockPanel Margin="0,8,0,0">
                        <TextBlock Text="📊 数据源列表" FontSize="16" FontWeight="SemiBold"/>
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                            <!-- 搜索框 -->
                            <TextBox Text="{Binding SearchText}" Watermark="🔍 搜索数据源..."
                                     Width="180" Padding="8,6"/>
                            <!-- 排序下拉框 -->
                            <ComboBox SelectedIndex="{Binding SortOption}" Width="120" Padding="8,6">
                                <ComboBoxItem Content="评分最高"/>
                                <ComboBoxItem Content="响应最快"/>
                                <ComboBoxItem Content="响应最慢"/>
                                <ComboBoxItem Content="评分最低"/>
                                <ComboBoxItem Content="评分最高"/>
                                <ComboBoxItem Content="名称排序"/>
                            </ComboBox>
                            <Button Content="全选" Command="{Binding SelectAllSourcesCommand}"
                                    Padding="8,4" FontSize="11"/>
                            <Button Content="取消" Command="{Binding DeselectAllSourcesCommand}"
                                    Padding="8,4" FontSize="11"/>
                            <TextBlock Text="{Binding SelectedSourcesCount, StringFormat='已选 {0} 个'}"
                                       FontSize="12" Classes="SecondaryText" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DockPanel>

                    <ItemsControl ItemsSource="{Binding FilteredSources}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:SourceStatusViewModel">
                                <Border Padding="16" Margin="0,0,0,8" CornerRadius="10"
                                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                        BorderThickness="1">
                                    <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto">
                                        <!-- 复选框 -->
                                        <CheckBox Grid.Column="0" 
                                                  IsChecked="{Binding IsSelected}"
                                                  Margin="0,0,12,0"
                                                  VerticalAlignment="Center"/>
                                        
                                        <!-- 状态指示灯 -->
                                        <Border Grid.Column="1" Width="36" Height="36" CornerRadius="18"
                                                Background="{Binding StatusColor}" Opacity="0.15"
                                                Margin="0,0,12,0">
                                            <TextBlock Text="🌐" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- 源名称 -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="Medium"/>
                                            <TextBlock Text="{Binding Url}" FontSize="10" Classes="SecondaryText"
                                                       TextWrapping="Wrap" MaxWidth="350"/>
                                        </StackPanel>

                                        <!-- 响应时间 -->
                                        <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="16,0" MinWidth="70">
                                            <TextBlock Text="响应" FontSize="9" Classes="SecondaryText" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding ResponseTimeText}" FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{Binding ResponseTimeColor}" HorizontalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- 评分 -->
                                        <StackPanel Grid.Column="4" VerticalAlignment="Center" Margin="16,0" MinWidth="50">
                                            <TextBlock Text="评分" FontSize="9" Classes="SecondaryText" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding ScoreText}" FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{Binding ScoreColor}" HorizontalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- 应用按钮 -->
                                        <Button Grid.Column="5" Content="应用" 
                                                Command="{Binding ApplySingleSourceCommand}"
                                                Padding="12,6" FontSize="11"
                                                VerticalAlignment="Center"
                                                Margin="12,0,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
                
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
