<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GithubAccelerator.UI.ViewModels"
        xmlns:views="using:GithubAccelerator.UI.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
        x:Class="GithubAccelerator.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="GitHub 加速器 Pro"
        Width="1000" Height="700"
        MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        CanResize="True"
        ShowInTaskbar="True">

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+R" Command="{Binding RefreshSourcesCommand}"/>
        <KeyBinding Gesture="Ctrl+S" Command="{Binding ApplyHostsCommand}"/>
        <KeyBinding Gesture="Ctrl+H" Command="{Binding ViewHostsContentCommand}"/>
        <KeyBinding Gesture="F5" Command="{Binding ToggleMonitoringCommand}"/>
    </Window.KeyBindings>

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.DataContext>
        <vm:MainWindowViewModel/>
    </Window.DataContext>

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Header - 顶部 -->
        <Border Grid.Row="0"
                Padding="20"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
            <Grid RowDefinitions="Auto,Auto">
                <!-- 第一行：标题和状态 -->
                <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto">
                    <!-- Logo和标题 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <TextBlock Text="🚀" FontSize="28" VerticalAlignment="Center"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="GitHub 加速器 Pro" FontSize="20" FontWeight="Bold"/>
                            <TextBlock Text="智能 Hosts 管理与加速工具" FontSize="11"
                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- 状态指示器 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Border Padding="12,6" CornerRadius="12"
                                Background="{DynamicResource SuccessColor}"
                                IsVisible="{Binding IsMonitoring}">
                            <TextBlock Text="● 监控中" FontSize="12" Foreground="White"/>
                        </Border>
                        <Border Padding="12,6" CornerRadius="12"
                                Background="{DynamicResource WarningColor}"
                                IsVisible="{Binding !IsMonitoring}">
                            <TextBlock Text="○ 已停止" FontSize="12" Foreground="White"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- 第二行：导航按钮 -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
                    <Button Content="📊 仪表盘" Command="{Binding ShowDashboardCommand}"
                            Padding="16,8" FontSize="13" FontWeight="Medium"/>
                    <Button Content="📈 性能图表" Command="{Binding ShowPerformanceChartCommand}"
                            Padding="16,8" FontSize="13" FontWeight="Medium"/>
                    <Button Content="🌐 GitHub 延迟" Command="{Binding ShowGitHubLatencyCommand}"
                            Padding="16,8" FontSize="13" FontWeight="Medium"/>
                    <Button Content="📄 Hosts" Command="{Binding ViewHostsContentCommand}"
                            Padding="16,8" FontSize="13" FontWeight="Medium"/>
                    <Button Content="📁 分组管理" Command="{Binding ShowHostsGroupManagerCommand}"
                            Padding="16,8" FontSize="13" FontWeight="Medium"/>
                    <Button Content="⚙️ 设置" Command="{Binding ShowSettingsCommand}"
                            Padding="16,8" FontSize="13" FontWeight="Medium"/>
                    <Button Content="📝 日志" Command="{Binding ShowLogViewerCommand}"
                            Padding="16,8" FontSize="13" FontWeight="Medium"/>
                    <Button Content="💾 备份" Command="{Binding ShowBackupManagerCommand}"
                            Padding="16,8" FontSize="13" FontWeight="Medium"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content Area - 中间内容区域 -->
        <Grid Grid.Row="1" RowDefinitions="*,Auto">
            <Border Grid.Row="0"
                    Padding="20"
                    Background="{DynamicResource BackgroundColor}">
                <ContentControl Content="{Binding CurrentView}"
                               HorizontalContentAlignment="Stretch"
                               VerticalContentAlignment="Stretch"/>
            </Border>

            <!-- 通知栏 -->
            <Border Grid.Row="1"
                    Padding="16,8"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    IsVisible="{Binding HasNotifications}">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0"
                               Text="{Binding LatestNotification}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                    <Button Grid.Column="1" Content="✕"
                            Command="{Binding DismissNotificationCommand}"
                            Padding="4,2" FontSize="10"
                            Background="Transparent" BorderThickness="0"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Footer - 底部状态栏 -->
        <Border Grid.Row="2"
                Padding="20,12"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           FontSize="11"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Content="{Binding IsDarkMode, Converter={StaticResource BoolToStringConverter}, ConverterParameter='☀️ 亮色 | 🌙 暗色'}"
                            Command="{Binding ToggleThemeCommand}"
                            Padding="8,4"
                            FontSize="11"
                            Background="Transparent"
                            BorderThickness="0"/>
                    <TextBlock Text="|"
                               FontSize="11"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               VerticalAlignment="Center"/>
                    <Button Content="关于"
                            Command="{Binding ShowAboutCommand}"
                            Padding="8,4"
                            FontSize="11"
                            Background="Transparent"
                            BorderThickness="0"/>
                    <TextBlock Text="|"
                               FontSize="11"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               VerticalAlignment="Center"/>
                    <Button Content="📤 导出" Command="{Binding ExportDataCommand}"
                            Padding="8,4" FontSize="11"
                            Background="Transparent" BorderThickness="0"/>
                    <Button Content="📥 导入" Command="{Binding ImportDataCommand}"
                            Padding="8,4" FontSize="11"
                            Background="Transparent" BorderThickness="0"/>
                    <TextBlock Text="|"
                               FontSize="11"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="v1.2.0"
                               FontSize="11"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
