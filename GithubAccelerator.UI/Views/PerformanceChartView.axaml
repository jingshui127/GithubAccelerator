<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:GithubAccelerator.UI.ViewModels"
             xmlns:ctrl="using:GithubAccelerator.UI.Controls"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="GithubAccelerator.UI.Views.PerformanceChartView"
             x:DataType="vm:PerformanceChartViewModel">

    <UserControl.Resources>
        <vm:ChartTypeBackgroundConverter x:Key="ChartTypeBgConverter"/>
        <vm:IsScoreDistributionConverter x:Key="IsScoreDistConverter"/>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*,Auto" Margin="0">
        <!-- 顶部工具栏 -->
        <Border Grid.Row="0" Padding="16,12" Margin="0,0,0,12"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                CornerRadius="12" BorderThickness="1"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock Text="📊 性能图表" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding ChartTitle}" FontSize="14"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 图表类型切换 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <Button Content="📈 趋势图" Command="{Binding SwitchToResponseTimeCommand}"
                            Padding="10,6" FontSize="12"
                            Background="{Binding SelectedChartType, Converter={StaticResource ChartTypeBgConverter}, ConverterParameter=0}"
                            BorderThickness="1"/>
                    <Button Content="📊 对比图" Command="{Binding SwitchToComparisonCommand}"
                            Padding="10,6" FontSize="12"
                            Background="{Binding SelectedChartType, Converter={StaticResource ChartTypeBgConverter}, ConverterParameter=1}"
                            BorderThickness="1"/>
                    <Button Content="📉 评分图" Command="{Binding SwitchToScoreDistributionCommand}"
                            Padding="10,6" FontSize="12"
                            Background="{Binding SelectedChartType, Converter={StaticResource ChartTypeBgConverter}, ConverterParameter=2}"
                            BorderThickness="1"/>
                </StackPanel>

                <!-- 数据源选择（评分图时显示） -->
                <ComboBox Grid.Column="2" ItemsSource="{Binding SourceNames}"
                          SelectedIndex="{Binding SelectedSourceIndex}"
                          MinWidth="140" Margin="8,0,0,0"
                          IsVisible="{Binding SelectedChartType, Converter={StaticResource IsScoreDistConverter}}"/>

                <Button Grid.Column="3" Content="🔄 刷新" Command="{Binding RefreshDataCommand}"
                        Padding="10,6" FontSize="12" Margin="8,0,0,0"/>
            </Grid>
        </Border>

        <!-- 图表区域 -->
        <Border Grid.Row="1" Padding="20"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                CornerRadius="12" BorderThickness="1"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
            <Grid>
                <!-- 折线图 -->
                <ctrl:SimpleLineChart IsVisible="{Binding IsLineChart}"
                                      Values="{Binding LineChartValues}"
                                      Title="{Binding ChartTitle}"
                                      YAxisLabel="{Binding YAxisName}"
                                      XAxisLabel="测试次数"
                                      MinY="0"
                                      MaxY="{Binding ChartMaxY}"
                                      LineColor="#4FC3F7"
                                      FillColor="#1A4FC3F7"
                                      AxisColor="#666666"
                                      TextColor="#999999"/>

                <!-- 柱状图 -->
                <ctrl:SimpleBarChart IsVisible="{Binding IsBarChart}"
                                     Items="{Binding BarItems}"
                                     Title="{Binding ChartTitle}"
                                     YAxisLabel="{Binding YAxisName}"
                                     MaxY="{Binding ChartMaxY}"
                                     AxisColor="#666666"
                                     TextColor="#999999"/>

                <!-- 空状态 -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Spacing="12"
                            IsVisible="{Binding HasNoData}">
                    <TextBlock Text="📊" FontSize="48" HorizontalAlignment="Center"/>
                    <TextBlock Text="暂无数据" FontSize="16" HorizontalAlignment="Center"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBlock Text="启动监控后，性能数据将在此处显示" FontSize="12"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 底部状态栏 -->
        <Border Grid.Row="2" Padding="12,8" Margin="0,12,0,0"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                CornerRadius="8" BorderThickness="1"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" FontSize="11"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding ChartUnit}" FontSize="11"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           VerticalAlignment="Center" Margin="0,0,16,0"/>
                <TextBlock Grid.Column="2" FontSize="11"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           VerticalAlignment="Center">
                    <Run Text="范围: "/>
                    <Run Text="{Binding ChartMinValue}"/>
                    <Run Text=" - "/>
                    <Run Text="{Binding ChartMaxValue}"/>
                    <Run Text=" "/>
                    <Run Text="{Binding ChartUnit}"/>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</UserControl>
