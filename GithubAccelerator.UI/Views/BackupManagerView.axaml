<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:GithubAccelerator.UI.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="500"
             x:Class="GithubAccelerator.UI.Views.BackupManagerView"
             x:DataType="vm:BackupManagerViewModel">

    <Design.DataContext>
        <vm:BackupManagerViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*" Margin="24">
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Grid.Column="0" Text="Hosts 备份管理" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
            
            <Button Grid.Column="1" Content="创建备份" Command="{Binding CreateBackupCommand}" 
                    Theme="{DynamicResource SuccessButton}"
                    Padding="12,4"/>
        </Grid>

        <Border Grid.Row="1" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" 
                BorderThickness="1" CornerRadius="8" 
                Background="{DynamicResource ControlFillColorDefaultBrush}">
            <ListBox ItemsSource="{Binding Backups}" 
                     Background="Transparent"
                     BorderThickness="0">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:BackupItemViewModel">
                        <Border Padding="12" Margin="0,0,0,1" BorderThickness="0,0,0,1" 
                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
                            <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding BackupTimeText}" FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Note}" FontSize="11" Classes="SecondaryText" 
                                               IsVisible="{Binding HasNote}"/>
                                </StackPanel>
                                
                                <Button Grid.Column="1" Content="恢复" Command="{Binding RestoreCommand}" 
                                        Theme="{DynamicResource PrimaryButton}"
                                        Padding="8,4" Margin="4,0"/>
                                
                                <Button Grid.Column="2" Content="查看" Command="{Binding ViewContentCommand}" 
                                        Theme="{DynamicResource SecondaryButton}"
                                        Padding="8,4" Margin="4,0"/>
                                
                                <Button Grid.Column="3" Content="删除" Command="{Binding DeleteCommand}" 
                                        Theme="{DynamicResource DangerButton}"
                                        Padding="8,4" Margin="4,0"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
    </Grid>
</UserControl>
