<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="GithubAccelerator.UI.App"
             xmlns:local="using:GithubAccelerator.UI"
             xmlns:semi="https://irihi.tech/semi"
             xmlns:converters="using:GithubAccelerator.UI.Converters"
             RequestedThemeVariant="Default">

    <Application.Resources>
        <converters:BoolToStringConverter x:Key="BoolToStringConverter"/>
        <converters:StringNotEmptyConverter x:Key="StringNotEmptyConverter"/>
        <converters:BoolToColorConverter x:Key="BoolToColorConverter"/>
        <converters:BoolToFontWeightConverter x:Key="BoolToFontWeightConverter"/>

        <!-- Theme Colors -->
        <Color x:Key="PrimaryColorValue">#0078D4</Color>
        <Color x:Key="SuccessColorValue">#107C10</Color>
        <Color x:Key="WarningColorValue">#FF8C00</Color>
        <Color x:Key="ErrorColorValue">#D13438</Color>
        <Color x:Key="PrimaryTextColor">#000000</Color>
        <Color x:Key="SecondaryTextColor">#666666</Color>
        <Color x:Key="PrimaryTextColorDark">#E0E0E0</Color>
        <Color x:Key="SecondaryTextColorDark">#9E9E9E</Color>

        <!-- Theme Brushes -->
        <SolidColorBrush x:Key="PrimaryColor" Color="{StaticResource PrimaryColorValue}"/>
        <SolidColorBrush x:Key="SuccessColor" Color="{StaticResource SuccessColorValue}"/>
        <SolidColorBrush x:Key="WarningColor" Color="{StaticResource WarningColorValue}"/>
        <SolidColorBrush x:Key="ErrorColor" Color="{StaticResource ErrorColorValue}"/>
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="{StaticResource PrimaryTextColor}"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource SecondaryTextColor}"/>
    </Application.Resources>

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <semi:SemiTheme Locale="zh-CN" />
        <StyleInclude Source="avares://GithubAccelerator.UI/Styles/CardStyles.axaml"/>
        
        <!-- Navigation Button Style -->
        <Style Selector="Button.NavButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        
        <!-- Navigation button hover/pressed (light) -->
        <Style Selector="Button.NavButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#E5E5E5"/>
        </Style>
        <Style Selector="Button.NavButton:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#D0D0D0"/>
        </Style>
        
        <!-- Navigation button text -->
        <Style Selector="Button.NavButton TextBlock">
            <Setter Property="Foreground" Value="#1A1A1A"/>
        </Style>
        
        <!-- Secondary text style -->
        <Style Selector="TextBlock.SecondaryText">
            <Setter Property="Foreground" Value="#666666"/>
        </Style>
    </Application.Styles>
</Application>
